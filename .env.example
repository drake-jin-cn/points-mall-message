# ============================================================
# points-mall-message — Environment Variables Reference
# Copy this file to .env.dev / .env.test / .env.prod and fill in real values.
# NEVER commit files with real secrets to Git.
# ============================================================

# ── JWT (Required — must match BFF JWT_SECRET exactly) ──────
JWT_SECRET=

# ── Application ─────────────────────────────────────────────
PORT=8082
# dev | test | prod  (controls which .env.{NODE_ENV} is loaded)
NODE_ENV=development

# ── PostgreSQL (Required) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=points_message
DB_USERNAME=postgres
DB_PASSWORD=

# ── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_URL=amqp://localhost:5672

# ── File Storage ────────────────────────────────────────────
# Local upload directory (relative to project root)
UPLOAD_DIR=./uploads
# Max file size in bytes (default 5 MB)
MAX_FILE_SIZE=5242880
